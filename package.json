{
  "name": "tetherstream",
  "version": "1.0.0",
  "description": "USDT micropayment streaming for AI agents - built for the Tether Hackathon",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "deploy:localhost": "hardhat run scripts/deploy.js --network localhost",
    "deploy:baseSepolia": "hardhat run scripts/deploy.js --network baseSepolia",
    "node": "hardhat node",
    "coverage": "hardhat coverage",
    "build": "cd frontend && npm install && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "vercel:deploy": "cd frontend && vercel --prod"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheMasterClaw/tether-hackathon-project.git"
  },
  "keywords": [
    "ethereum",
    "solidity",
    "usdt",
    "tether",
    "streaming",
    "payments",
    "ai-agents",
    "base",
    "hackathon"
  ],
  "author": "PayStream Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TheMasterClaw/tether-hackathon-project/issues"
  },
  "homepage": "https://github.com/TheMasterClaw/tether-hackathon-project#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.6.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "ethers": "^6.16.0",
    "gitnexus": "^1.4.7",
    "hardhat": "^2.22.18",
    "hardhat-gas-reporter": "^1.0.10",
    "playwright": "^1.58.2",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
