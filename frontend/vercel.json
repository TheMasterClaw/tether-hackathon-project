{
  "version": 2,
  "outputDirectory": "dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/landing", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
